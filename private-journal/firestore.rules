rules_version = '2';

// =========================================================
// Marginalia — Firestore security rules
//
// Data model:
//   /users/{uid}/entries/{entryId}
//
// Every entry lives under a document named after the owning
// user's Firebase Auth UID. These rules ensure a signed-in
// user can only ever read or write documents under their own
// UID — never another user's — and that every write matches
// the schema we expect.
// =========================================================
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {

      // The parent /users/{userId} document itself is not used
      // to store data; deny direct access to it.
      allow read, write: if false;

      match /entries/{entryId} {

        // Only the owning, signed-in user may read their entries.
        allow read: if isOwner(userId);

        // Creating an entry: must be the owner, and the payload
        // must match the expected shape (no extra/unexpected fields,
        // correct types, timestamps present).
        allow create: if isOwner(userId) && isValidEntry();

        // Updating an entry: must be the owner and the result
        // must still match the expected shape. createdAt may not
        // be changed after creation.
        allow update: if isOwner(userId)
                       && isValidEntry()
                       && request.resource.data.createdAt == resource.data.createdAt;

        // Deleting an entry: owner only.
        allow delete: if isOwner(userId);
      }
    }

    // Everything else is denied by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }

  function isOwner(userId) {
    return request.auth != null && request.auth.uid == userId;
  }

  function isValidEntry() {
    let data = request.resource.data;
    return data.keys().hasOnly(['title', 'body', 'createdAt', 'updatedAt'])
      && data.title is string
      && data.title.size() <= 300
      && data.body is string
      && data.body.size() <= 200000
      && data.createdAt is timestamp
      && data.updatedAt is timestamp;
  }
}
